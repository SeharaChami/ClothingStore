<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="620.0" prefWidth="980.0" styleClass="app-root" stylesheets="@../../styles/app.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="edu.icet.demo.controller.user.EmployeeHomeController">

   <VBox alignment="CENTER" maxWidth="440.0" spacing="14.0" styleClass="card">
      <padding>
         <Insets bottom="44.0" left="44.0" right="44.0" top="44.0" />
      </padding>
      <ImageView fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
         <Image url="@../../images/logo.png" />
      </ImageView>
      <Label fx:id="lblWelcome" styleClass="badge" text="Welcome!" />
      <Label styleClass="title-1" text="What would you like to do?" />
      <Label alignment="CENTER" styleClass="subtitle" text="Pick a service to get started." textAlignment="CENTER" wrapText="true" />
      <Region prefHeight="8.0" />
      <ComboBox fx:id="servicesCmb" maxWidth="1.7976931348623157E308" promptText="Choose a service…" />
      <Button fx:id="btnContinue" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnContinueOnAction" styleClass="btn-primary" text="Continue" />
      <Button fx:id="btnExit" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#btnExitOnAction" styleClass="btn-ghost" text="Log out" />
   </VBox>
</StackPane>
