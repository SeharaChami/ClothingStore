<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620.0" prefWidth="980.0" styleClass="app-root" stylesheets="@../../styles/app.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.icet.demo.controller.supplier.SupplierController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="14.0">
         <padding>
            <Insets bottom="14.0" left="28.0" right="28.0" top="22.0" />
         </padding>
         <Label styleClass="title-1" text="Suppliers" />
         <Label styleClass="badge" text="PARTNERS" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnBack" mnemonicParsing="false" onAction="#backOnAction" styleClass="btn-ghost" text="← Back to dashboard" />
      </HBox>
   </top>

   <center>
      <TableView fx:id="tblSuppliers" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colSupId" prefWidth="90.0" text="Id" />
            <TableColumn fx:id="colSupName" prefWidth="170.0" text="Supplier" />
            <TableColumn fx:id="colCompany" prefWidth="170.0" text="Company" />
            <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="22.0" left="28.0" right="14.0" />
         </BorderPane.margin>
      </TableView>
   </center>

   <right>
      <VBox prefWidth="300.0" spacing="9.0" styleClass="card" BorderPane.alignment="TOP_CENTER">
         <padding>
            <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="22.0" right="28.0" />
         </BorderPane.margin>
         <Label styleClass="title-2" text="Supplier details" />
         <Label fx:id="lblSupId" styleClass="badge-success" text="(auto)" />

         <Label styleClass="form-label" text="NAME *" />
         <TextField fx:id="txtSupName" promptText="e.g. Nimal Perera" />

         <Label styleClass="form-label" text="COMPANY" />
         <TextField fx:id="txtCompany" promptText="e.g. Softline Textiles Ltd." />

         <Label styleClass="form-label" text="EMAIL" />
         <TextField fx:id="txtEmail" promptText="e.g. sales@softline.com" />

         <Region prefHeight="6.0" />
         <Button fx:id="btnNewSupplier" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#addSupplierOnAction" styleClass="btn-primary" text="Add supplier" />
         <HBox spacing="10.0">
            <Button fx:id="btnUpdateSupplier" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#updateSupplierOnAction" styleClass="btn-secondary" text="Update" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnDeleteSupplier" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#deleteSupplierOnAction" styleClass="btn-danger" text="Delete" HBox.hgrow="ALWAYS" />
         </HBox>
         <Button fx:id="btnClear" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clearOnAction" styleClass="btn-ghost" text="Clear form" />
      </VBox>
   </right>
</BorderPane>
