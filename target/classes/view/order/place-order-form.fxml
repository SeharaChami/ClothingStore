<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="660.0" prefWidth="1040.0" styleClass="app-root" stylesheets="@../../styles/app.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.icet.demo.controller.order.PlaceOrderContoller">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="14.0">
         <padding>
            <Insets bottom="12.0" left="28.0" right="28.0" top="20.0" />
         </padding>
         <Label styleClass="title-1" text="New order" />
         <Label fx:id="lblOrderId" styleClass="badge" text="(auto)" />
         <Label fx:id="lblDate" styleClass="badge-success" text="today" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnBack" mnemonicParsing="false" onAction="#backOnAction" styleClass="btn-ghost" text="← Back to orders" />
      </HBox>
   </top>

   <left>
      <VBox prefWidth="330.0" spacing="14.0">
         <padding>
            <Insets bottom="22.0" left="28.0" />
         </padding>

         <!-- customer card -->
         <VBox spacing="8.0" styleClass="card">
            <padding>
               <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
            </padding>
            <Label styleClass="title-2" text="Customer" />
            <Label styleClass="form-label" text="EXISTING CUSTOMER" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <ComboBox fx:id="cmbCustomerId" prefWidth="130.0" promptText="Id…" />
               <Label fx:id="lblCustomerName" styleClass="subtitle" text="" wrapText="true" HBox.hgrow="ALWAYS" />
            </HBox>
            <Separator />
            <Label styleClass="form-label" text="…OR REGISTER A NEW ONE" />
            <TextField fx:id="txtCusName" promptText="Name" />
            <TextField fx:id="txtCusEmail" promptText="Email (optional)" />
            <TextField fx:id="txtCusAddress" promptText="Address (optional)" />
            <Button fx:id="btnAddCustomer" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#addCustomerOnAction" styleClass="btn-secondary" text="Register customer" />
         </VBox>

         <!-- product card -->
         <VBox spacing="8.0" styleClass="card">
            <padding>
               <Insets bottom="18.0" left="20.0" right="20.0" top="18.0" />
            </padding>
            <Label styleClass="title-2" text="Add product" />
            <ComboBox fx:id="cmbProductId" maxWidth="1.7976931348623157E308" promptText="Choose a product…" />
            <Label fx:id="lblProductDetails" styleClass="subtitle" text="" wrapText="true" />
            <HBox spacing="10.0">
               <TextField fx:id="txtQty" promptText="Qty" HBox.hgrow="ALWAYS" />
               <Button fx:id="btnAddToCart" mnemonicParsing="false" onAction="#addToCartOnAction" styleClass="btn-secondary" text="Add to cart" />
            </HBox>
         </VBox>
      </VBox>
   </left>

   <center>
      <VBox spacing="12.0">
         <padding>
            <Insets bottom="22.0" left="14.0" right="28.0" />
         </padding>
         <TableView fx:id="tblCart" VBox.vgrow="ALWAYS">
            <columns>
               <TableColumn fx:id="colProductId" prefWidth="90.0" text="Id" />
               <TableColumn fx:id="colProductName" prefWidth="180.0" text="Product" />
               <TableColumn fx:id="colQty" prefWidth="70.0" text="Qty" />
               <TableColumn fx:id="colUnitPrice" prefWidth="110.0" text="Unit price" />
               <TableColumn fx:id="colTotal" prefWidth="110.0" text="Total" />
            </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         </TableView>
         <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="card-soft">
            <padding>
               <Insets bottom="14.0" left="20.0" right="20.0" top="14.0" />
            </padding>
            <Button fx:id="btnRemoveItem" mnemonicParsing="false" onAction="#removeItemOnAction" styleClass="btn-danger" text="Remove line" />
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="form-label" text="TOTAL" />
            <Label fx:id="lblTotal" styleClass="total-label" text="0.00" />
            <Button fx:id="btnPlaceOrder" mnemonicParsing="false" onAction="#placeOrderOnAction" styleClass="btn-primary" text="Place order" />
         </HBox>
      </VBox>
   </center>
</BorderPane>
