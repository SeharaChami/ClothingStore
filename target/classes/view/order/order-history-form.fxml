<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="620.0" prefWidth="980.0" styleClass="app-root" stylesheets="@../../styles/app.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.icet.demo.controller.order.OrderHistoryController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="14.0">
         <padding>
            <Insets bottom="14.0" left="28.0" right="28.0" top="22.0" />
         </padding>
         <Label styleClass="title-1" text="Order history" />
         <Label fx:id="lblSummary" styleClass="badge-success" text="…" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnBack" mnemonicParsing="false" onAction="#backOnAction" styleClass="btn-ghost" text="← Back to orders" />
      </HBox>
   </top>

   <center>
      <TableView fx:id="tblOrders" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colOrderId" prefWidth="100.0" text="Order id" />
            <TableColumn fx:id="colCusId" prefWidth="100.0" text="Customer" />
            <TableColumn fx:id="colDate" prefWidth="160.0" text="Date" />
            <TableColumn fx:id="colAmount" prefWidth="120.0" text="Amount" />
            <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="22.0" left="28.0" right="28.0" />
         </BorderPane.margin>
      </TableView>
   </center>
</BorderPane>
