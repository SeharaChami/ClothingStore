<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620.0" prefWidth="980.0" styleClass="app-root" stylesheets="@../../styles/app.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.icet.demo.controller.product.ProductController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="14.0">
         <padding>
            <Insets bottom="14.0" left="28.0" right="28.0" top="22.0" />
         </padding>
         <Label styleClass="title-1" text="Products" />
         <Label styleClass="badge" text="CATALOGUE" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnBack" mnemonicParsing="false" onAction="#backOnAction" styleClass="btn-ghost" text="← Back to dashboard" />
      </HBox>
   </top>

   <center>
      <TableView fx:id="tblProducts" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn fx:id="colProductId" prefWidth="80.0" text="Id" />
            <TableColumn fx:id="colProductName" prefWidth="170.0" text="Product" />
            <TableColumn fx:id="colCategory" prefWidth="90.0" text="Category" />
            <TableColumn fx:id="colSize" prefWidth="60.0" text="Size" />
            <TableColumn fx:id="colQty" prefWidth="80.0" text="In stock" />
            <TableColumn fx:id="colUnitPrice" prefWidth="110.0" text="Unit price" />
            <TableColumn fx:id="colSupId" prefWidth="90.0" text="Supplier" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <BorderPane.margin>
            <Insets bottom="22.0" left="28.0" right="14.0" />
         </BorderPane.margin>
      </TableView>
   </center>

   <right>
      <VBox prefWidth="300.0" spacing="9.0" styleClass="card" BorderPane.alignment="TOP_CENTER">
         <padding>
            <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="22.0" right="28.0" />
         </BorderPane.margin>
         <Label styleClass="title-2" text="Product details" />
         <Label fx:id="lblProductId" styleClass="badge-success" text="(auto)" />

         <Label styleClass="form-label" text="NAME *" />
         <TextField fx:id="txtProductName" promptText="e.g. Cotton T-shirt" />

         <Label styleClass="form-label" text="CATEGORY *" />
         <ComboBox fx:id="categoryCmb" maxWidth="1.7976931348623157E308" promptText="Choose…" />

         <HBox spacing="10.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
               <Label styleClass="form-label" text="SIZE" />
               <TextField fx:id="txtSize" promptText="e.g. 10" />
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
               <Label styleClass="form-label" text="QUANTITY *" />
               <TextField fx:id="txtQty" promptText="e.g. 25" />
            </VBox>
         </HBox>

         <Label styleClass="form-label" text="UNIT PRICE *" />
         <TextField fx:id="txtUnitPrice" promptText="e.g. 1490.00" />

         <Label styleClass="form-label" text="SUPPLIER" />
         <ComboBox fx:id="cmbSupId" maxWidth="1.7976931348623157E308" promptText="Supplier id…" />

         <Region prefHeight="6.0" />
         <Button fx:id="btnNewProduct" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#addProductOnAction" styleClass="btn-primary" text="Add product" />
         <HBox spacing="10.0">
            <Button fx:id="btnUpdateProduct" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#updateProductOnAction" styleClass="btn-secondary" text="Update" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnDeleteProduct" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#deleteProductOnAction" styleClass="btn-danger" text="Delete" HBox.hgrow="ALWAYS" />
         </HBox>
         <Button fx:id="btnClear" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clearOnAction" styleClass="btn-ghost" text="Clear form" />
      </VBox>
   </right>
</BorderPane>
